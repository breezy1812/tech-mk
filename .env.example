APP_NAME=phase1-tech-km
APP_ENV=dev
APP_PORT=8000
APP_BASE_URL=http://your-internal-host:8000
LOG_LEVEL=INFO

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_SYSTEM_PROMPT=你是一個部署在私有伺服器上的技術資料管理助手。請用清楚、保守、可落地的方式回答。

TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_POLLING_TIMEOUT_SECONDS=30
TELEGRAM_POLLING_LIMIT=100
TELEGRAM_POLLING_RETRY_DELAY_SECONDS=5
TELEGRAM_ADMIN_USER_IDS=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

RAG_ENABLED=true
RAG_DOCS_ROOT=data/docs
RAG_VECTOR_STORE_PATH=data/vector_store
RAG_COLLECTION_NAME=tech_docs
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_MAX_CHUNKS_PER_FILE=2000
RAG_TOP_K=3
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_EMBEDDING_TIMEOUT_SECONDS=60
RAG_EMBEDDING_BATCH_SIZE=32
RAG_LOADER_TIMEOUT_SECONDS=120
RAG_ALLOW_REINDEX=false
RAG_QUERY_DEBUG_DEFAULT=false
RAG_CHROMA_ANONYMIZED_TELEMETRY=false

